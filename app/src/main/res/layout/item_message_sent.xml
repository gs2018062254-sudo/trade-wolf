<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="end"
    android:orientation="vertical"
    android:paddingStart="64dp"
    android:paddingTop="4dp"
    android:paddingEnd="8dp"
    android:paddingBottom="4dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMessageSent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#5B3DF5"
        app:cardCornerRadius="20dp"
        app:cardElevation="3dp"
        app:strokeColor="#885B3DF5"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="290dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivMessageImage"
                android:layout_width="240dp"
                android:layout_height="180dp"
                android:adjustViewBounds="true"
                android:background="#2A1E6E"
                android:contentDescription="Imagen enviada"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/llAudioMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="10dp"
                android:background="#2A1E6E"
                android:visibility="gone">
                
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPlayAudio"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:icon="@android:drawable/ic_media_play"
                    app:iconTint="#FFFFFF"
                    app:iconPadding="0dp"
                    app:cornerRadius="20dp"
                    app:backgroundTint="#5B3DF5"
                    android:contentDescription="Reproducir audio" />
                
                <TextView
                    android:id="@+id/tvAudioDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="10dp"
                    android:textColor="#FFFFFF"
                    android:text="Audio" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvMessageText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="280dp"
                android:paddingStart="14dp"
                android:paddingTop="10dp"
                android:paddingEnd="14dp"
                android:paddingBottom="8dp"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:lineSpacingExtra="2dp" />

            <TextView
                android:id="@+id/tvMessageTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="8dp"
                android:textColor="#D7D1FF"
                android:textSize="11sp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>