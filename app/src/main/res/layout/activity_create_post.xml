<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/tvTituloCrearPost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Crear publicación"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvSubtituloCrearPost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Publica productos, servicios o anuncios para otros usuarios"
            android:textAlignment="center"
            android:textColor="#A8B1D1"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="18dp" />

        <LinearLayout
            android:id="@+id/panelCrearPublicacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_filter_panel">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Imagen de la publicación"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="210dp"
                android:background="@drawable/bg_search_futuristic">

                <ImageView
                    android:id="@+id/ivPreviewImagen"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:contentDescription="Vista previa de imagen" />

                <TextView
                    android:id="@+id/tvImagenHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vista previa"
                    android:textColor="#B8C2F0"
                    android:textSize="14sp"
                    android:background="#66000000"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="12dp" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTomarFoto"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Tomar foto"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    app:backgroundTint="#5B3DF5"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_camera"
                    app:iconTint="#FFFFFF" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCargarImagen"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Cargar imagen"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    app:backgroundTint="#00C853"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_upload"
                    app:iconTint="#FFFFFF" />

            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:hint="Título"
                app:boxBackgroundColor="#3310182F"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxStrokeColor="#2EE6FF"
                app:hintTextColor="#A8B1D1"
                app:startIconDrawable="@android:drawable/ic_menu_edit"
                app:startIconTint="#2EE6FF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTitulo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#8E9AC7"
                    android:textSize="15sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputDescripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Descripción"
                app:boxBackgroundColor="#3310182F"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxStrokeColor="#5B3DF5"
                app:hintTextColor="#A8B1D1"
                app:startIconDrawable="@android:drawable/ic_menu_info_details"
                app:startIconTint="#5B3DF5">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDescripcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:inputType="textMultiLine|textCapSentences"
                    android:minLines="3"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#8E9AC7"
                    android:textSize="15sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Categoría"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spCategoria"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_spinner_futuristic"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:popupBackground="#151B33" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tipo de publicación"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spTipo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_spinner_futuristic"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:popupBackground="#151B33" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputPrecio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="Precio o 'A coordinar'"
                app:boxBackgroundColor="#3310182F"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxStrokeColor="#00C853"
                app:hintTextColor="#A8B1D1"
                app:startIconDrawable="@android:drawable/ic_menu_manage"
                app:startIconTint="#00C853">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPrecio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#8E9AC7"
                    android:textSize="15sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputWhatsapp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="WhatsApp"
                app:boxBackgroundColor="#3310182F"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="18dp"
                app:boxCornerRadiusTopEnd="18dp"
                app:boxCornerRadiusBottomStart="18dp"
                app:boxCornerRadiusBottomEnd="18dp"
                app:boxStrokeColor="#FFC107"
                app:hintTextColor="#A8B1D1"
                app:startIconDrawable="@android:drawable/ic_menu_call"
                app:startIconTint="#FFC107">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWhatsapp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#8E9AC7"
                    android:textSize="15sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <EditText
                android:id="@+id/etImagenUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:inputType="textUri" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPublicar"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="22dp"
                android:text="Publicar"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#2EE6FF"
                app:cornerRadius="18dp"
                app:icon="@android:drawable/ic_menu_send"
                app:iconTint="#FFFFFF" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>