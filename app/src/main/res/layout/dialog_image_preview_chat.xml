<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#10182F"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enviar imagen"
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <ImageView
        android:id="@+id/ivPreviewChatImage"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="#1C2545"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery"
        android:contentDescription="Vista previa de imagen" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Mensaje opcional"
        android:layout_marginTop="14dp"
        app:boxBackgroundColor="#18213D"
        app:boxBackgroundMode="filled"
        app:boxCornerRadiusTopStart="18dp"
        app:boxCornerRadiusTopEnd="18dp"
        app:boxCornerRadiusBottomStart="18dp"
        app:boxCornerRadiusBottomEnd="18dp"
        app:boxStrokeColor="#2EE6FF"
        app:hintTextColor="#A8B1D1">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCaptionImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLines="3"
            android:textColor="#FFFFFF"
            android:textColorHint="#A8B1D1" />

    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="14dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelImage"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Cancelar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:backgroundTint="#FF4D6D"
            app:cornerRadius="16dp" />

        <Space
            android:layout_width="10dp"
            android:layout_height="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSendImage"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Enviar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:backgroundTint="#00C853"
            app:cornerRadius="16dp"
            app:icon="@android:drawable/ic_menu_send"
            app:iconTint="#FFFFFF" />

    </LinearLayout>

</LinearLayout>